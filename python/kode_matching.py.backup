#!/usr/bin/env python3
"""
KODE MATCHING - Match text dengan variabel pelanggaran/apresiasi/konselor
"""

import sys


def match_kode_variabel(text_original, tokens_stemmed, db):
    """
    Match text dengan variabel dari database
    
    Args:
        text_original (str): Original text
        tokens_stemmed (list): Stemmed tokens
        db (DatabaseHelper): Database connection
        
    Returns:
        list: Matched kode variabel (e.g., ['P001', 'P005'])
    """
    matched_kode = []
    
    try:
        # Get all variabel kata from database
        all_kata = db.get_all_variabel_kata()
        
        if not all_kata:
            print("✗ No variabel kata loaded from database", file=sys.stderr)
            return []
        
        # Create lowercase version for matching
        text_lower = text_original.lower()
        tokens_lower = [t.lower() for t in tokens_stemmed]
        
        # Track which kode already matched (avoid duplicates)
        matched_kode_set = set()
        
        # Match each variabel kata
        for item in all_kata:
            kata = item['kata'].lower().strip()
            kode = item['kode']
            kategori = item.get('kategori', 'unknown')
            
            # Skip empty kata
            if not kata:
                continue
            
            # Check if kata appears in text or stemmed tokens
            if kata in text_lower or kata in tokens_lower:
                if kode not in matched_kode_set:
                    matched_kode_set.add(kode)
                    print(f"✓ Matched '{kata}' → {kode} ({kategori})", file=sys.stderr)
        
        matched_kode = sorted(list(matched_kode_set))
        
        if matched_kode:
            print(f"✓ Total matched kode: {len(matched_kode)} → {matched_kode}", file=sys.stderr)
        else:
            print("✗ No kode matched", file=sys.stderr)
        
        return matched_kode
        
    except Exception as e:
        print(f"✗ Error in match_kode_variabel: {e}", file=sys.stderr)
        return []


def categorize_kode(kode_list):
    """
    Categorize kode by type
    
    Args:
        kode_list (list): List of kode (e.g., ['P001', 'A002', 'K001'])
        
    Returns:
        dict: {
            'pelanggaran': ['P001'],
            'apresiasi': ['A002'],
            'konselor': ['K001']
        }
    """
    result = {
        'pelanggaran': [],
        'apresiasi': [],
        'konselor': []
    }
    
    for kode in kode_list:
        if kode.startswith('P'):
            result['pelanggaran'].append(kode)
        elif kode.startswith('A'):
            result['apresiasi'].append(kode)
        elif kode.startswith('K'):
            result['konselor'].append(kode)
    
    return result