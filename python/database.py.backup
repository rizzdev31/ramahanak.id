#!/usr/bin/env python3
"""
Database Helper - CORRECT VERSION
Mengambil kata dari variabel_pelanggaran, bukan dari kamus_kata
"""

import sys
import mysql.connector
from mysql.connector import Error


class DatabaseHelper:
    """Database operations helper"""
    
    def __init__(self, host, user, password, database):
        self.connection = None
        try:
            self.connection = mysql.connector.connect(
                host=host,
                user=user,
                password=password,
                database=database
            )
            if self.connection.is_connected():
                print(f"✓ Connected to database: {database}", file=sys.stderr)
        except Error as e:
            print(f"✗ Database connection error: {e}", file=sys.stderr)
            raise
    
    def get_laporan_awal(self, laporan_id):
        """Get laporan_awal by ID"""
        try:
            cursor = self.connection.cursor(dictionary=True)
            query = "SELECT * FROM laporan_awal WHERE id = %s"
            cursor.execute(query, (laporan_id,))
            result = cursor.fetchone()
            cursor.close()
            
            if result:
                print(f"✓ Found laporan_awal: {laporan_id}", file=sys.stderr)
            else:
                print(f"✗ Laporan not found: {laporan_id}", file=sys.stderr)
            
            return result
        except Error as e:
            print(f"✗ Error fetching laporan: {e}", file=sys.stderr)
            return None
    
    def get_santri_by_name(self, nama):
        """
        Get santri with MULTIPLE fallback strategies
        """
        if not nama:
            return None
        
        nama_lower = nama.lower().strip()
        
        try:
            cursor = self.connection.cursor(dictionary=True)
            
            # Strategy 1: Exact match nama_panggilan
            query1 = """
                SELECT u.id, sp.nama_lengkap, sp.nama_panggilan, sp.nisn
                FROM users u
                JOIN santri_profiles sp ON u.id = sp.user_id
                WHERE LOWER(TRIM(sp.nama_panggilan)) = %s
                AND u.role = 'santri' 
                AND u.status = 'active'
                LIMIT 1
            """
            cursor.execute(query1, (nama_lower,))
            result = cursor.fetchone()
            
            if result:
                print(f"✓ Exact match (nama_panggilan): {nama} → {result['nama_panggilan']}", file=sys.stderr)
                cursor.close()
                return result
            
            # Strategy 2: Partial match nama_lengkap
            query2 = """
                SELECT u.id, sp.nama_lengkap, sp.nama_panggilan, sp.nisn
                FROM users u
                JOIN santri_profiles sp ON u.id = sp.user_id
                WHERE LOWER(sp.nama_lengkap) LIKE %s
                AND u.role = 'santri' 
                AND u.status = 'active'
                LIMIT 1
            """
            cursor.execute(query2, (f'%{nama_lower}%',))
            result = cursor.fetchone()
            
            if result:
                print(f"✓ Partial match (nama_lengkap): {nama} → {result['nama_panggilan']}", file=sys.stderr)
                cursor.close()
                return result
            
            # Strategy 3: Partial match nama_panggilan
            query3 = """
                SELECT u.id, sp.nama_lengkap, sp.nama_panggilan, sp.nisn
                FROM users u
                JOIN santri_profiles sp ON u.id = sp.user_id
                WHERE LOWER(sp.nama_panggilan) LIKE %s
                AND u.role = 'santri' 
                AND u.status = 'active'
                LIMIT 1
            """
            cursor.execute(query3, (f'%{nama_lower}%',))
            result = cursor.fetchone()
            
            if result:
                print(f"✓ Partial match (nama_panggilan): {nama} → {result['nama_panggilan']}", file=sys.stderr)
                cursor.close()
                return result
            
            print(f"✗ NOT FOUND in database: {nama}", file=sys.stderr)
            cursor.close()
            return None
            
        except Error as e:
            print(f"✗ Database error: {e}", file=sys.stderr)
            return None
    
    def get_kamus_kata(self):
        """
        ✅ FIX: Ambil kata dari variabel_pelanggaran.kamus_kata
        
        Returns:
            list: [{kata: str, kategori: str}, ...]
        """
        try:
            cursor = self.connection.cursor(dictionary=True)
            
            # Ambil dari variabel_pelanggaran
            query = "SELECT kode, kamus_kata FROM variabel_pelanggaran"
            cursor.execute(query)
            results = cursor.fetchall()
            cursor.close()
            
            # Parse comma-separated kamus_kata
            kata_list = []
            for row in results:
                if row['kamus_kata']:
                    # Split by comma
                    kata_items = row['kamus_kata'].split(',')
                    for kata in kata_items:
                        kata = kata.strip()
                        if kata:
                            kata_list.append({
                                'kata': kata,
                                'kategori': 'pelanggaran',
                                'kode': row['kode']
                            })
            
            print(f"✓ Loaded {len(kata_list)} kata from variabel_pelanggaran", file=sys.stderr)
            return kata_list
            
        except Error as e:
            print(f"✗ Error fetching kamus_kata: {e}", file=sys.stderr)
            # ✅ Return empty list instead of crashing
            return []
    
    def get_all_variabel_kata(self):
        """
        ✅ NEW: Get kata dari SEMUA variabel (pelanggaran, apresiasi, konselor)
        """
        all_kata = []
        
        try:
            cursor = self.connection.cursor(dictionary=True)
            
            # 1. Pelanggaran
            cursor.execute("SELECT kode, kamus_kata FROM variabel_pelanggaran")
            for row in cursor.fetchall():
                if row['kamus_kata']:
                    for kata in row['kamus_kata'].split(','):
                        kata = kata.strip()
                        if kata:
                            all_kata.append({
                                'kata': kata,
                                'kategori': 'pelanggaran',
                                'kode': row['kode']
                            })
            
            # 2. Apresiasi (if exists)
            try:
                cursor.execute("SELECT kode, kamus_kata FROM variabel_apresiasi")
                for row in cursor.fetchall():
                    if row['kamus_kata']:
                        for kata in row['kamus_kata'].split(','):
                            kata = kata.strip()
                            if kata:
                                all_kata.append({
                                    'kata': kata,
                                    'kategori': 'apresiasi',
                                    'kode': row['kode']
                                })
            except Error:
                pass
            
            # 3. Konselor (if exists)
            try:
                cursor.execute("SELECT kode, kamus_kata FROM variabel_konselor")
                for row in cursor.fetchall():
                    if row['kamus_kata']:
                        for kata in row['kamus_kata'].split(','):
                            kata = kata.strip()
                            if kata:
                                all_kata.append({
                                    'kata': kata,
                                    'kategori': 'konselor',
                                    'kode': row['kode']
                                })
            except Error:
                pass
            
            cursor.close()
            print(f"✓ Loaded {len(all_kata)} kata from all variabel tables", file=sys.stderr)
            return all_kata
            
        except Error as e:
            print(f"✗ Error fetching variabel kata: {e}", file=sys.stderr)
            return []
    
    def save_hasil_preprocessing(self, data):
        """Save hasil preprocessing to database"""
        try:
            cursor = self.connection.cursor()
            
            query = """
                INSERT INTO hasil_preprocessing (
                    laporan_awal_id,
                    kode_matched,
                    pelaku_nama,
                    pelaku_santri_id,
                    korban_nama,
                    korban_santri_id,
                    kata_kerja_dasar,
                    preprocessing_data,
                    status,
                    processed_at
                ) VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, NOW())
            """
            
            import json
            values = (
                data['laporan_id'],
                json.dumps(data['kode_matched']),
                data.get('pelaku_nama'),
                data.get('pelaku_santri_id'),
                data.get('korban_nama'),
                data.get('korban_santri_id'),
                data.get('kata_kerja_dasar'),
                json.dumps(data.get('preprocessing_data', {})),
                'pending_validasi'
            )
            
            cursor.execute(query, values)
            self.connection.commit()
            
            hasil_id = cursor.lastrowid
            cursor.close()
            
            print(f"✓ Saved to database: hasil_preprocessing_id={hasil_id}", file=sys.stderr)
            return hasil_id
            
        except Error as e:
            print(f"✗ Error saving hasil: {e}", file=sys.stderr)
            if self.connection:
                self.connection.rollback()
            return None
    
    def close(self):
        """Close database connection"""
        if self.connection and self.connection.is_connected():
            self.connection.close()
            print("✓ Database connection closed", file=sys.stderr)


def get_db():
    """Get database connection from environment"""
    import os
    from dotenv import load_dotenv
    
    # Load .env dari parent directory
    env_path = os.path.join(os.path.dirname(__file__), '..', '.env')
    load_dotenv(env_path)
    
    return DatabaseHelper(
        host=os.getenv('DB_HOST', 'localhost'),
        user=os.getenv('DB_USERNAME', 'root'),
        password=os.getenv('DB_PASSWORD', ''),
        database=os.getenv('DB_DATABASE', 'db_ra')
    )